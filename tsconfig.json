{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["vite/client", "react", "react-dom", "node"],
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"],
      "imports/*": ["imports/*"]
    },
  },
  "include": ["src"]
}